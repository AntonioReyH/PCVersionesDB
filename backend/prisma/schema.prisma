generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model IPRecord {
  id        Int      @id @default(autoincrement())
  addressV4 String   @unique
  addressV6 String?  
  etiqueta  String   
  
  createdAt DateTime @default(now())
}

model Usuario {
  id        String   @id @default(uuid())
  email     String   @unique
  nombre    String
  cargoId   String?  // Opcional al principio, hasta que se le asigne uno
  cargo     Cargo?   @relation(fields: [cargoId], references: [id])
  createdAt DateTime @default(now())
}

model Cargo {
  id          String    @id @default(uuid())
  nombre      String    @unique // Ej: "MASTER", "DPO", "AUDITOR_LEGAL", "OPERADOR"
  descripcion String?
  usuarios    Usuario[]
}