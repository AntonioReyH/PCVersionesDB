generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model IPRecord {
  id        Int      @id @default(autoincrement())
  addressV4 String   @unique
  addressV6 String?  // <-- NUEVA COLUMNA (Soporte IPv6)
  etiqueta  String   // Se mantiene de la v3/v4
  createdAt DateTime @default(now())
}