generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model IPRecord {
  id        Int      @id @default(autoincrement())
  addressV4 String   @unique
  notas     String?  
  etiqueta  String   // <-- NUEVA COLUMNA OBLIGATORIA (El dato proyectado)
  createdAt DateTime @default(now())
}