generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model IPRecord {
  id        Int      @id @default(autoincrement())
  addressV4 String   @unique
  etiqueta  String   // Mantenemos el dato proyectado
  createdAt DateTime @default(now())
}